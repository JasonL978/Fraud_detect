# Copy to .env and adjust as needed.  .env is gitignored.

# --- Kafka / Redpanda ---
# Host-facing bootstrap (use this from scripts/producers running on your machine).
KAFKA_BOOTSTRAP=localhost:19092
# In-cluster bootstrap (use this from other containers).
KAFKA_BOOTSTRAP_INTERNAL=redpanda:9092

# --- Schema Registry ---
SCHEMA_REGISTRY_URL=http://localhost:18081

# --- Topics ---
TOPIC_TRANSACTIONS=transactions.v1

# --- Console UI ---
CONSOLE_URL=http://localhost:8080
